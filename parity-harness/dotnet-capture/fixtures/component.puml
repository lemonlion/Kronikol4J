@startuml
left to right direction
skinparam defaultTextAlignment center
skinparam wrapWidth 200
skinparam shadowing false
skinparam rectangle<<person>> {
  BackgroundColor #08427B
  FontColor #FFFFFF
  BorderColor #073B6F
  RoundCorner 25
  StereotypeFontColor #08427B
  StereotypeFontSize 0
}
skinparam rectangle<<system>> {
  BackgroundColor #438DD5
  FontColor #FFFFFF
  BorderColor #3C7FC0
  RoundCorner 25
  StereotypeFontColor #438DD5
  StereotypeFontSize 0
}
skinparam database {
  BackgroundColor #E74C3C
  FontColor #FFFFFF
  BorderColor #C0392B
}
skinparam collections {
  BackgroundColor #F39C12
  FontColor #FFFFFF
  BorderColor #D68910
}
skinparam queue {
  BackgroundColor #9B59B6
  FontColor #FFFFFF
  BorderColor #7D3C98
}
skinparam arrow {
  Color #666666
  FontColor #666666
  FontSize 11
}

title Component Diagram

rectangle "**Test**\n<size:10>[Person]</size>" as test <<person>>
rectangle "**OrderService**\n<size:10>[Software System]</size>" as orderService <<system>>
database "OrderDb" as orderDb
collections "CartCache" as cartCache

test -[#438DD5]-> orderService : "HTTP: POST - 1 calls across 1 tests"
test -[#E74C3C]-> orderDb : "SQL: SELECT - 1 calls across 1 tests"
test -[#F39C12]-> cartCache : "Redis: GET - 1 calls across 1 tests"

@enduml
