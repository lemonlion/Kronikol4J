@startuml
!pragma teoz true


skinparam wrapWidth 800
autonumber 1

actor "Test" as test
entity "ApiService" as apiService

test -> apiService: POST: /graphql\n(query GetUser)
note left
query GetUser($id: ID!) {
  user(id: $id) {
    id
    name
    email
  }
}
end note
apiService --> test: OK
note right
{
  "data": {
    "user": {
      "id": "42",
      "name": "Ada"
    }
  }
}
end note
@enduml
