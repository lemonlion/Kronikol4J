@startuml
!pragma teoz true


skinparam wrapWidth 800
autonumber 1

actor "Test" as test
entity "ApiService" as apiService

test -> apiService: POST: /graphql\n(query GetUser)
note left
<color:gray>[Authorization=Bearer xyz]
<color:gray>[Content-Type=application/json]

query GetUser($id: ID!) {
  user(id: $id) {
    id
    name
    email
  }
}

variables:
{
  "id": "42",
  "note": "a\\u003Cb\\u003E\\u0026c\\u002Bd"
}
end note
apiService --> test: OK
note right
{
  "data": {
    "user": {
      "id": "42",
      "name": "Ada"
    }
  }
}
end note
@enduml
