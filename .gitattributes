# Normalize text to LF in the repo; check out platform-native.
* text=auto eol=lf
*.bat text eol=crlf
*.jar binary
gradlew text eol=lf

# Internal-flow activity-diagram fixtures intentionally hold native (CRLF) line endings — the report
# gzips this PlantUML into puml-data before its ReplaceLineEndings, so the bytes must survive verbatim.
kronikol4j-report/src/test/resources/parity/iflow-*.txt -text
